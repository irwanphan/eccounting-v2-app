{
  "name": "@eccounting/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared business types & Zod schemas dipakai api + web",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
