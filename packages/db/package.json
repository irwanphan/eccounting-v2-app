{
  "name": "@eccounting/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle ORM schema + raw SQL migrations runner untuk Eccounting v2",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./dist/src/schema/index.d.ts",
      "import": "./dist/src/schema/index.js",
      "default": "./dist/src/schema/index.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js",
      "default": "./dist/src/client.js"
    },
    "./tenant": {
      "types": "./dist/src/tenant.d.ts",
      "import": "./dist/src/tenant.js",
      "default": "./dist/src/tenant.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "migrate": "tsx scripts/run-migrations.ts",
    "seed": "tsx scripts/run-seeds.ts",
    "reset": "tsx scripts/reset-db.ts",
    "bootstrap-from-v1": "tsx scripts/bootstrap-from-v1.ts",
    "set-dev-password": "tsx scripts/set-dev-password.ts",
    "studio": "drizzle-kit studio",
    "introspect": "drizzle-kit introspect"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.3",
    "pg": "^8.13.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@eccounting/config": "workspace:*",
    "@node-rs/argon2": "^1.8.3",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "mysql2": "^3.11.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
