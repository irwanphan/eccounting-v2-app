{
  "name": "@eccounting/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle ORM schema + raw SQL migrations runner untuk Eccounting v2",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./tenant": "./src/tenant.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "migrate": "tsx scripts/run-migrations.ts",
    "seed": "tsx scripts/run-seeds.ts",
    "reset": "tsx scripts/reset-db.ts",
    "studio": "drizzle-kit studio",
    "introspect": "drizzle-kit introspect"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.3",
    "pg": "^8.13.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@eccounting/config": "workspace:*",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
