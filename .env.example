################################################################################
# Eccounting v2 — environment example
# Copy ke `.env` lalu sesuaikan untuk lokal/staging/production.
################################################################################

NODE_ENV=development
APP_NAME=Eccounting
APP_TIMEZONE=Asia/Jakarta

# -------- PostgreSQL --------
POSTGRES_DB=eccounting_v2
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection URL untuk Drizzle / NestJS (pakai role app_user di production)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eccounting_v2
DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/eccounting_v2

# Role passwords (di-set saat menjalankan setup-roles.sh)
APP_USER_PASSWORD=change_me_app_user
APP_ADMIN_PASSWORD=change_me_app_admin
APP_OWNER_PASSWORD=change_me_app_owner

# -------- Redis (queue + cache) --------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -------- S3 / MinIO (file storage import Excel) --------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=eccounting-imports
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -------- Mail (dev: mailhog) --------
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@eccounting.local
MAIL_FROM_NAME=Eccounting
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# -------- API (NestJS) --------
API_PORT=3001
API_GLOBAL_PREFIX=v1
API_CORS_ORIGINS=http://localhost:3000
SWAGGER_PATH=docs
SWAGGER_ENABLED=true

# -------- Auth (JWT) --------
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=change_me_to_random_64_chars_minimum_for_security_in_production_xxxxxxxxx
JWT_ISSUER=eccounting-api
JWT_AUDIENCE=eccounting-web
JWT_ACCESS_TTL_SECONDS=900           # 15 menit
REFRESH_TOKEN_TTL_SECONDS=2592000    # 30 hari
PASSWORD_RESET_TTL_SECONDS=3600      # 1 jam

# -------- v1 MySQL (untuk bootstrap & ETL) --------
V1_MYSQL_HOST=127.0.0.1
V1_MYSQL_PORT=8889
V1_MYSQL_USER=root
V1_MYSQL_PASSWORD=root
V1_MYSQL_DATABASE=eccounting_1_prod
FIRM_NAME=KKP Siaw Ban Hin SE BKP
FIRM_TIMEZONE=Asia/Jakarta

# -------- Web (Next.js) --------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_APP_NAME=Eccounting

# -------- Telemetry & logs --------
LOG_LEVEL=info
LOG_FORMAT=pretty
SENTRY_DSN=
